# Participant scratch workspace — never tracked, keeps `git pull` conflict-free.
my-progress/*
!my-progress/README.md

# Generated run output, not the reference solution content.
**/outputs/*
!**/outputs/.gitkeep

# Secrets — never commit these, per doc §11 Security requirements.
.env
*.env
.env.*
**/data/private/
*.sqlite
*.sqlite3

# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/
.ipynb_checkpoints/

# Node
node_modules/

# OS / editor cruft
.DS_Store
Thumbs.db
