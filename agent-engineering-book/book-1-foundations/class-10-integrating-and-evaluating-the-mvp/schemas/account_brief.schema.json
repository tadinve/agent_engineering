{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "account_brief.schema.json",
  "title": "Account Brief (Chapter 5.6)",
  "description": "The versioned contract connecting research, reasoning, composition and review. schema_version is required on every instance so later additions (memory references, production lineage, Book 2+) can be introduced without breaking readers of an older brief.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "company_profile",
    "signals",
    "stakeholder_roles",
    "hypotheses",
    "evidence",
    "outreach_drafts",
    "reviewer_findings",
    "approval_status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },

    "company_profile": { "$ref": "#/$defs/company_profile" },
    "signals": { "type": "array", "items": { "$ref": "#/$defs/signal" } },
    "stakeholder_roles": { "type": "array", "items": { "$ref": "#/$defs/stakeholder_role" } },
    "hypotheses": { "type": "array", "items": { "$ref": "#/$defs/hypothesis" } },
    "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence_item" } },
    "outreach_drafts": { "type": "array", "items": { "$ref": "#/$defs/outreach_draft" } },
    "reviewer_findings": { "type": "array", "items": { "$ref": "#/$defs/reviewer_finding" } },
    "approval_status": { "$ref": "#/$defs/approval_status" },

    "error": { "$ref": "#/$defs/error_object" }
  },

  "$defs": {
    "evidence_item": {
      "description": "Chapter 7.2-7.5 additive fields: source_type, staleness_justification and conflicts_with are all optional so a Chapter 5/6-era evidence_item still validates unchanged (schema_version 1.1.0 — a minor, non-breaking addition, not a new major).",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id", "source", "source_date", "retrieval_date",
        "evidence_text", "confidence", "claim_type", "support_type"
      ],
      "properties": {
        "evidence_id": { "type": "string", "pattern": "^EV-[0-9]{3,}$" },
        "source": { "type": "string", "minLength": 1 },
        "source_type": {
          "description": "Ch. 7.2 — recorded so reviewers can weigh evidence strength by source kind, not just presence of a source.",
          "type": "string",
          "enum": [
            "official_company_source", "regulatory_filing",
            "news_publication", "industry_analyst", "aggregator_or_unverified"
          ]
        },
        "source_date": { "type": "string", "format": "date" },
        "retrieval_date": { "type": "string", "format": "date" },
        "evidence_text": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "claim_type": { "type": "string", "enum": ["fact", "inference", "hypothesis"] },
        "support_type": { "type": "string", "enum": ["direct", "derived", "unsupported"] },
        "staleness_justification": {
          "description": "Ch. 7.5 / evidence-policy.yaml rejection_conditions — the explicit note a source older than staleness_days needs to remain usable.",
          "type": ["string", "null"]
        },
        "conflicts_with": {
          "description": "Ch. 7.5 — other evidence_ids this item disagrees with. Recording the conflict is required; silently picking one source instead is exactly what this field exists to prevent.",
          "type": "array",
          "items": { "type": "string", "pattern": "^EV-[0-9]{3,}$" }
        }
      }
    },

    "company_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "company", "industry", "size_estimate", "business_model", "evidence_ids"
      ],
      "properties": {
        "company": { "type": "string", "minLength": 1 },
        "industry": { "type": "string", "minLength": 1 },
        "size_estimate": { "type": "string", "minLength": 1 },
        "business_model": { "type": "string", "minLength": 1 },
        "evidence_ids": { "type": "array", "items": { "type": "string" } }
      }
    },

    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signal_id", "description", "category", "evidence_ids"],
      "properties": {
        "signal_id": { "type": "string", "pattern": "^SIG-[0-9]{3,}$" },
        "description": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": [
            "leadership", "funding", "hiring", "product",
            "acquisition", "regulatory", "expansion", "layoffs"
          ]
        },
        "evidence_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },

    "stakeholder_role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role_title", "likely_person", "evidence_ids"],
      "properties": {
        "role_title": { "type": "string", "minLength": 1 },
        "likely_person": { "type": ["string", "null"] },
        "evidence_ids": { "type": "array", "items": { "type": "string" } }
      },
      "allOf": [
        {
          "description": "A named person requires evidence (Ch. 10.2) — an empty evidence list with a named person is exactly the fabrication CLAUDE.md prohibits.",
          "if": { "properties": { "likely_person": { "type": "string" } } },
          "then": { "properties": { "evidence_ids": { "type": "array", "minItems": 1 } } }
        }
      ]
    },

    "hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hypothesis_id", "statement", "classification", "evidence_ids", "confidence"],
      "properties": {
        "hypothesis_id": { "type": "string", "pattern": "^HYP-[0-9]{3,}$" },
        "statement": { "type": "string", "minLength": 1 },
        "classification": { "type": "string", "enum": ["fact", "inference", "hypothesis"] },
        "evidence_ids": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },

    "outreach_draft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message_type", "text", "word_count"],
      "properties": {
        "message_type": {
          "type": "string",
          "enum": ["email", "linkedin_connection_note", "meeting_opening_question"]
        },
        "text": { "type": "string", "minLength": 1 },
        "word_count": { "type": "integer", "minimum": 0 }
      }
    },

    "reviewer_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_id", "target_id", "verdict", "reason"],
      "properties": {
        "finding_id": { "type": "string", "pattern": "^RF-[0-9]{3,}$" },
        "target_id": { "type": "string", "minLength": 1 },
        "verdict": { "type": "string", "enum": ["approved", "rejected", "needs_revision"] },
        "reason": { "type": "string", "minLength": 1 }
      }
    },

    "approval_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "decided_by", "decided_at"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["draft", "pending_approval", "approved", "rejected"]
        },
        "decided_by": { "type": ["string", "null"] },
        "decided_at": { "type": ["string", "null"], "format": "date" }
      }
    },

    "error_object": {
      "description": "Ch. 5.4 — what a failed or partial stage reports, distinct from a successful result.",
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "error_type", "attempted_action", "recoverable", "message"],
      "properties": {
        "stage": { "type": "string", "minLength": 1 },
        "error_type": { "type": "string", "minLength": 1 },
        "attempted_action": { "type": "string", "minLength": 1 },
        "recoverable": { "type": "boolean" },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
