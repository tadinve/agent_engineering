{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Company Profiler output (Chapter 7.6)",
  "description": "Standalone Skill output; the same evidence_item shape used in schemas/account_brief.schema.json so this can later be merged into a full Account Brief without translation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["company", "industry", "size_estimate", "business_model", "evidence_ids", "evidence"],
  "properties": {
    "company": { "type": "string", "minLength": 1 },
    "industry": { "type": "string", "minLength": 1 },
    "size_estimate": { "type": "string", "minLength": 1 },
    "business_model": { "type": "string", "minLength": 1 },
    "evidence_ids": { "type": "array", "items": { "type": "string", "pattern": "^EV-[0-9]{3,}$" } },
    "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence_item" } }
  },
  "$defs": {
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id", "source", "source_date", "retrieval_date",
        "evidence_text", "confidence", "claim_type", "support_type"
      ],
      "properties": {
        "evidence_id": { "type": "string", "pattern": "^EV-[0-9]{3,}$" },
        "source": { "type": "string", "minLength": 1 },
        "source_type": {
          "type": "string",
          "enum": [
            "official_company_source", "regulatory_filing",
            "news_publication", "industry_analyst", "aggregator_or_unverified"
          ]
        },
        "source_date": { "type": "string", "format": "date" },
        "retrieval_date": { "type": "string", "format": "date" },
        "evidence_text": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "claim_type": { "type": "string", "enum": ["fact", "inference", "hypothesis"] },
        "support_type": { "type": "string", "enum": ["direct", "derived", "unsupported"] },
        "staleness_justification": { "type": ["string", "null"] },
        "conflicts_with": { "type": "array", "items": { "type": "string", "pattern": "^EV-[0-9]{3,}$" } }
      }
    }
  }
}
